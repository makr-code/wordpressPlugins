{
    "$schema": "https://schemas.wp.org/trunk/theme.json",
    "version": 2,
    "settings": {
        "appearanceTools": true,
        "useRootPaddingAwareAlignments": true,
        "layout": {
            "contentSize": "800px",
            "wideSize": "1200px"
        },
        "spacing": {
            "spacingScale": {
                "operator": "*",
                "increment": 1.5,
                "steps": 7,
                "mediumStep": 1.5,
                "unit": "rem"
            },
            "spacingSizes": [
                { "name": "1 (4px)",   "slug": "1",  "size": "0.25rem" },
                { "name": "2 (8px)",   "slug": "2",  "size": "0.5rem"  },
                { "name": "3 (12px)",  "slug": "3",  "size": "0.75rem" },
                { "name": "4 (16px)",  "slug": "4",  "size": "1rem"    },
                { "name": "5 (20px)",  "slug": "5",  "size": "1.25rem" },
                { "name": "6 (24px)",  "slug": "6",  "size": "1.5rem"  },
                { "name": "8 (32px)",  "slug": "8",  "size": "2rem"    },
                { "name": "10 (40px)", "slug": "10", "size": "2.5rem"  },
                { "name": "12 (48px)", "slug": "12", "size": "3rem"    },
                { "name": "16 (64px)", "slug": "16", "size": "4rem"    },
                { "name": "20 (80px)", "slug": "20", "size": "5rem"    },
                { "name": "24 (96px)", "slug": "24", "size": "6rem"    }
            ],
            "units": ["%", "px", "em", "rem", "vh", "vw"]
        },
        "color": {
            "defaultDuotone": false,
            "defaultGradients": false,
            "defaultPalette": false,
            "duotone": [],
            "gradients": [
                {
                    "name": "TV3 Hero",
                    "slug": "tv3-hero",
                    "gradient": "linear-gradient(160deg, #001a33 0%, #003366 45%, #00509e 100%)"
                },
                {
                    "name": "TV3 Azure",
                    "slug": "tv3-azure",
                    "gradient": "linear-gradient(135deg, #0078d4 0%, #005a9e 100%)"
                },
                {
                    "name": "TV3 Navy",
                    "slug": "tv3-navy",
                    "gradient": "linear-gradient(135deg, #003366 0%, #001a33 100%)"
                },
                {
                    "name": "TV3 Cyan",
                    "slug": "tv3-cyan",
                    "gradient": "linear-gradient(135deg, #00b7c3 0%, #50e6ff 100%)"
                },
                {
                    "name": "TV3 Accent",
                    "slug": "tv3-accent",
                    "gradient": "linear-gradient(135deg, #0078d4 0%, #50e6ff 100%)"
                }
            ],
            "palette": [
                {
                    "name": "TV3 Navy",
                    "slug": "tv3-navy",
                    "color": "#003366"
                },
                {
                    "name": "TV3 Navy Dark",
                    "slug": "tv3-navy-dark",
                    "color": "#001a33"
                },
                {
                    "name": "TV3 Navy Mid",
                    "slug": "tv3-navy-mid",
                    "color": "#00509e"
                },
                {
                    "name": "TV3 Azure",
                    "slug": "tv3-azure",
                    "color": "#0078d4"
                },
                {
                    "name": "TV3 Azure Dark",
                    "slug": "tv3-azure-dark",
                    "color": "#005a9e"
                },
                {
                    "name": "TV3 Azure Light",
                    "slug": "tv3-azure-light",
                    "color": "#2899f5"
                },
                {
                    "name": "TV3 Azure Pale",
                    "slug": "tv3-azure-pale",
                    "color": "#cfe4fc"
                },
                {
                    "name": "TV3 Cyan",
                    "slug": "tv3-cyan",
                    "color": "#50e6ff"
                },
                {
                    "name": "TV3 Teal",
                    "slug": "tv3-teal",
                    "color": "#008080"
                },
                {
                    "name": "TV3 Green",
                    "slug": "tv3-green",
                    "color": "#107c10"
                },
                {
                    "name": "TV3 Red",
                    "slug": "tv3-red",
                    "color": "#d13438"
                },
                {
                    "name": "TV3 Yellow",
                    "slug": "tv3-yellow",
                    "color": "#ffb900"
                },
                {
                    "name": "White",
                    "slug": "white",
                    "color": "#ffffff"
                },
                {
                    "name": "Gray 50",
                    "slug": "gray-50",
                    "color": "#f5f7fa"
                },
                {
                    "name": "Gray 100",
                    "slug": "gray-100",
                    "color": "#eef2f7"
                },
                {
                    "name": "Gray 200",
                    "slug": "gray-200",
                    "color": "#dde3ec"
                },
                {
                    "name": "Gray 400",
                    "slug": "gray-400",
                    "color": "#8fa3bc"
                },
                {
                    "name": "Gray 500",
                    "slug": "gray-500",
                    "color": "#6c7f96"
                },
                {
                    "name": "Text On Dark",
                    "slug": "text-on-dark",
                    "color": "#e8eef5"
                },
                {
                    "name": "Dark Background",
                    "slug": "bg-dark",
                    "color": "#003366"
                },
                {
                    "name": "Darker Background",
                    "slug": "bg-darker",
                    "color": "#001a33"
                }
            ]
        },
        "typography": {
            "customFontSize": true,
            "defaultFontSizes": false,
            "dropCap": false,
            "fontSizes": [
                { "name": "XS (12px)",  "slug": "xs",   "size": "0.75rem"  },
                { "name": "SM (14px)",  "slug": "sm",   "size": "0.875rem" },
                { "name": "Base (16px)","slug": "base", "size": "1rem"     },
                { "name": "MD (18px)",  "slug": "md",   "size": "1.125rem" },
                { "name": "LG (20px)",  "slug": "lg",   "size": "1.25rem"  },
                { "name": "XL (24px)",  "slug": "xl",   "size": "1.5rem"   },
                { "name": "2XL (30px)", "slug": "2xl",  "size": "1.875rem" },
                { "name": "3XL (36px)", "slug": "3xl",  "size": "2.25rem"  },
                { "name": "4XL (48px)", "slug": "4xl",  "size": "3rem"     },
                { "name": "5XL (60px)", "slug": "5xl",  "size": "3.75rem"  }
            ],
            "fontFamilies": [
                {
                    "name": "System UI Sans",
                    "slug": "system-sans",
                    "fontFamily": "\"Segoe UI\", -apple-system, BlinkMacSystemFont, Roboto, \"Helvetica Neue\", Arial, sans-serif"
                },
                {
                    "name": "Monospace",
                    "slug": "mono",
                    "fontFamily": "\"Cascadia Code\", \"SFMono-Regular\", Consolas, \"Liberation Mono\", Menlo, monospace"
                }
            ],
            "fluid": true
        },
        "blocks": {
            "core/button": {
                "color": {
                    "palette": [
                        { "name": "TV3 Azure",     "slug": "tv3-azure",      "color": "#0078d4" },
                        { "name": "TV3 Navy",      "slug": "tv3-navy",       "color": "#003366" },
                        { "name": "TV3 Cyan",      "slug": "tv3-cyan",       "color": "#50e6ff" },
                        { "name": "White",         "slug": "white",          "color": "#ffffff" }
                    ]
                }
            },
            "core/navigation": {
                "layout": {
                    "default": { "type": "flex", "orientation": "horizontal" }
                }
            },
            "core/code": {
                "color": {
                    "background": "#0d1821",
                    "text": "#cdd9e5"
                }
            }
        }
    },
    "styles": {
        "color": {
            "background": "#ffffff",
            "text": "#12202f"
        },
        "typography": {
            "fontFamily": "var:preset|font-family|system-sans",
            "fontSize": "var:preset|font-size|base",
            "lineHeight": "1.7",
            "letterSpacing": "-0.01em"
        },
        "spacing": {
            "blockGap": "var:preset|spacing|6"
        },
        "elements": {
            "link": {
                "color": { "text": "var:preset|color|tv3-azure" },
                ":hover": {
                    "color": { "text": "var:preset|color|tv3-azure-dark" }
                }
            },
            "button": {
                "color": {
                    "background": "var:preset|color|tv3-azure",
                    "text": "var:preset|color|white"
                },
                "border": {
                    "radius": "8px"
                },
                "spacing": {
                    "padding": {
                        "top": "var:preset|spacing|3",
                        "bottom": "var:preset|spacing|3",
                        "left": "var:preset|spacing|6",
                        "right": "var:preset|spacing|6"
                    }
                },
                "typography": {
                    "fontWeight": "600",
                    "fontSize": "var:preset|font-size|base"
                },
                ":hover": {
                    "color": {
                        "background": "var:preset|color|tv3-azure-dark",
                        "text": "var:preset|color|white"
                    }
                }
            },
            "h1": {
                "typography": {
                    "fontSize": "var:preset|font-size|4xl",
                    "fontWeight": "800",
                    "lineHeight": "1.12",
                    "letterSpacing": "-0.04em"
                }
            },
            "h2": {
                "typography": {
                    "fontSize": "var:preset|font-size|3xl",
                    "fontWeight": "700",
                    "lineHeight": "1.22",
                    "letterSpacing": "-0.03em"
                }
            },
            "h3": {
                "typography": {
                    "fontSize": "var:preset|font-size|2xl",
                    "fontWeight": "700",
                    "lineHeight": "1.3",
                    "letterSpacing": "-0.02em"
                }
            },
            "h4": {
                "typography": {
                    "fontSize": "var:preset|font-size|xl",
                    "fontWeight": "700",
                    "lineHeight": "1.4"
                }
            },
            "h5": {
                "typography": {
                    "fontSize": "var:preset|font-size|lg",
                    "fontWeight": "600",
                    "lineHeight": "1.5"
                }
            },
            "h6": {
                "typography": {
                    "fontSize": "var:preset|font-size|md",
                    "fontWeight": "600",
                    "lineHeight": "1.5"
                }
            }
        },
        "blocks": {
            "core/site-title": {
                "typography": {
                    "fontSize": "var:preset|font-size|lg",
                    "fontWeight": "700",
                    "letterSpacing": "-0.03em"
                }
            },
            "core/navigation": {
                "typography": {
                    "fontSize": "var:preset|font-size|sm",
                    "fontWeight": "500"
                }
            },
            "core/post-title": {
                "typography": {
                    "fontSize": "var:preset|font-size|4xl",
                    "fontWeight": "800",
                    "lineHeight": "1.12",
                    "letterSpacing": "-0.04em"
                }
            },
            "core/code": {
                "color": {
                    "background": "#0d1821",
                    "text": "#cdd9e5"
                },
                "typography": {
                    "fontFamily": "var:preset|font-family|mono",
                    "fontSize": "var:preset|font-size|sm"
                },
                "spacing": {
                    "padding": {
                        "top": "var:preset|spacing|6",
                        "bottom": "var:preset|spacing|6",
                        "left": "var:preset|spacing|6",
                        "right": "var:preset|spacing|6"
                    }
                },
                "border": { "radius": "12px" }
            },
            "core/quote": {
                "border": {
                    "color": "var:preset|color|tv3-azure",
                    "style": "solid",
                    "width": "0",
                    "left": { "width": "4px" }
                },
                "color": {
                    "background": "var:preset|color|gray-50"
                },
                "spacing": {
                    "padding": {
                        "top": "var:preset|spacing|4",
                        "bottom": "var:preset|spacing|4",
                        "left": "var:preset|spacing|6",
                        "right": "var:preset|spacing|6"
                    }
                }
            },
            "core/table": {
                "color": {
                    "background": "var:preset|color|white"
                },
                "border": {
                    "radius": "12px"
                }
            },
            "core/separator": {
                "color": {
                    "text": "var:preset|color|gray-200"
                }
            },
            "core/pullquote": {
                "border": {
                    "color": "var:preset|color|tv3-azure",
                    "style": "solid",
                    "top": { "width": "3px" },
                    "bottom": { "width": "3px" }
                },
                "color": {
                    "text": "var:preset|color|tv3-navy"
                },
                "typography": {
                    "fontSize": "var:preset|font-size|xl",
                    "fontStyle": "italic"
                }
            }
        }
    },
    "templateParts": [
        { "name": "header",           "title": "Header",              "area": "header" },
        { "name": "header-docs",      "title": "Header – Docs",       "area": "header" },
        { "name": "footer",           "title": "Footer",              "area": "footer" },
        { "name": "announcement-bar", "title": "Announcement Bar",    "area": "uncategorized" },
        { "name": "page-hero",        "title": "Page Hero",           "area": "uncategorized" },
        { "name": "breadcrumbs",      "title": "Breadcrumbs",         "area": "uncategorized" },
        { "name": "post-meta",        "title": "Post Meta",           "area": "uncategorized" },
        { "name": "post-navigation",  "title": "Post Navigation",     "area": "uncategorized" },
        { "name": "cta-banner",       "title": "CTA Banner",          "area": "uncategorized" },
        { "name": "search-bar",       "title": "Search Bar",          "area": "uncategorized" },
        { "name": "sidebar-docs",     "title": "Sidebar – Docs",      "area": "uncategorized" },
        { "name": "404-content",      "title": "404 Content",         "area": "uncategorized" }
    ],
    "customTemplates": [
        {
            "name": "front-page",
            "title": "Front Page",
            "postTypes": ["page"]
        },
        {
            "name": "page-docs",
            "title": "Documentation Page",
            "postTypes": ["page"]
        },
        {
            "name": "page-full-width",
            "title": "Full Width Page",
            "postTypes": ["page"]
        },
        {
            "name": "single",
            "title": "Single Post",
            "postTypes": ["post"]
        },
        {
            "name": "index",
            "title": "Blog Index",
            "postTypes": ["post"]
        },
        {
            "name": "page",
            "title": "Page",
            "postTypes": ["page"]
        },
        {
            "name": "404",
            "title": "404 Not Found",
            "postTypes": []
        }
    ],
    "patterns": [
        "themisdb-v3/hero-home",
        "themisdb-v3/feature-cards",
        "themisdb-v3/stats-bar",
        "themisdb-v3/cta-download",
        "themisdb-v3/docs-grid",
        "themisdb-v3/query-showcase",
        "themisdb-v3/pricing-section",
        "themisdb-v3/tabs-section",
        "themisdb-v3/testimonial"
    ]
}
