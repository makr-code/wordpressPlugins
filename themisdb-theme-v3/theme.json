    "styles": {
        "color": {
            "background": "#ffffff",
            "text": "#111827"
        },
        "typography": {
            "fontFamily": "var:preset|font-family|system-sans",
            "fontSize": "var:preset|font-size|base",
            "lineHeight": "1.7",
            "letterSpacing": "-0.01em"
        },
        "spacing": {
            "blockGap": "var:preset|spacing|6"
        },
        "elements": {
            "link": {
                "color": {
                    "text": "var:preset|color|tv3-azure"
                },
                ":hover": {
                    "color": {
                        "text": "var:preset|color|tv3-azure-dark"
                    }
                }
            },
            "button": {
                "color": {
                    "background": "var:preset|color|tv3-azure",
                    "text": "var:preset|color|white"
                },
                "border": {
                    "radius": "8px"
                },
                "spacing": {
                    "padding": {
                        "top": "var:preset|spacing|3",
                        "bottom": "var:preset|spacing|3",
                        "left": "var:preset|spacing|6",
                        "right": "var:preset|spacing|6"
                    }
                },
                "typography": {
                    "fontWeight": "600",
                    "fontSize": "var:preset|font-size|base"
                },
                ":hover": {
                    "color": {
                        "background": "var:preset|color|tv3-azure-dark",
                        "text": "var:preset|color|white"
                    }
                }
            },
            "h1": {
                "typography": {
                    "fontSize": "var:preset|font-size|4xl",
                    "fontWeight": "800",
                    "lineHeight": "1.12",
                    "letterSpacing": "-0.04em"
                }
            },
            "h2": {
                "typography": {
                    "fontSize": "var:preset|font-size|3xl",
                    "fontWeight": "700",
                    "lineHeight": "1.22",
                    "letterSpacing": "-0.03em"
                }
            },
            "h3": {
                "typography": {
                    "fontSize": "var:preset|font-size|2xl",
                    "fontWeight": "700",
                    "lineHeight": "1.3",
                    "letterSpacing": "-0.02em"
                }
            },
            "h4": {
                "typography": {
                    "fontSize": "var:preset|font-size|xl",
                    "fontWeight": "700",
                    "lineHeight": "1.4"
                }
            },
            "h5": {
                "typography": {
                    "fontSize": "var:preset|font-size|lg",
                    "fontWeight": "600",
                    "lineHeight": "1.5"
                }
            },
            "h6": {
                "typography": {
                    "fontSize": "var:preset|font-size|md",
                    "fontWeight": "600",
                    "lineHeight": "1.5"
                }
            }
        },
        "blocks": {
            "core/site-title": {
                "typography": {
                    "fontSize": "var:preset|font-size|lg",
                    "fontWeight": "700",
                    "letterSpacing": "-0.03em"
                }
            },
            "core/navigation": {
                "typography": {
                    "fontSize": "var:preset|font-size|sm",
                    "fontWeight": "500"
                }
            },
            "core/post-title": {
                "typography": {
                    "fontSize": "var:preset|font-size|4xl",
                    "fontWeight": "800",
                    "lineHeight": "1.12",
                    "letterSpacing": "-0.04em"
                }
            },
            "core/code": {
                "color": {
                    "background": "#0d1e32",
                    "text": "#c8d8e8"
                },
                "typography": {
                    "fontFamily": "var:preset|font-family|mono",
                    "fontSize": "var:preset|font-size|sm"
                },
                "spacing": {
                    "padding": {
                        "top": "var:preset|spacing|6",
                        "bottom": "var:preset|spacing|6",
                        "left": "var:preset|spacing|6",
                        "right": "var:preset|spacing|6"
                    }
                },
                "border": {
                    "radius": "12px"
                }
            },
            "core/quote": {
                "border": {
                    "color": "var:preset|color|tv3-azure",
                    "style": "solid",
                    "width": "0",
                    "left": {
                        "width": "4px"
                    }
                },
                "color": {
                    "background": "var:preset|color|gray-50"
                },
                "spacing": {
                    "padding": {
                        "top": "var:preset|spacing|4",
                        "bottom": "var:preset|spacing|4",
                        "left": "var:preset|spacing|6",
                        "right": "var:preset|spacing|6"
                    }
                }
            },
            "core/table": {
                "color": {
                    "background": "var:preset|color|white"
                },
                "border": {
                    "radius": "12px"
                }
            },
            "core/separator": {
                "color": {
                    "text": "var:preset|color|gray-200"
                }
            },
            "core/pullquote": {
                "border": {
                    "color": "var:preset|color|tv3-azure",
                    "style": "solid",
                    "top": {
                        "width": "3px"
                    },
                    "bottom": {
                        "width": "3px"
                    }
                },
                "color": {
                    "text": "var:preset|color|tv3-navy"
                },
                "typography": {
                    "fontSize": "var:preset|font-size|xl",
                    "fontStyle": "italic"
                }
            }
        }
    },
