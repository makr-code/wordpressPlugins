{
  "$schema": "https://schemas.wp.org/wp/6.8/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "color": {
      "defaultDuotone": false,
      "defaultGradients": false,
      "defaultPalette": false,
      "palette": [
        {
          "color": "#222222",
          "name": "Heading",
          "slug": "heading"
        },
        {
          "color": "#4E4E4E",
          "name": "Paragraph",
          "slug": "paragraph"
        },
        {
          "color": "#10B981",
          "name": "Primary",
          "slug": "primary"
        },
        {
          "color": "#FFFFFF",
          "name": "Background 1",
          "slug": "background-1"
        },
        {
          "color": "#FAFAFA",
          "name": "Background 2 (gray)",
          "slug": "background-2"
        },
        {
          "color": "#F5F9F8",
          "name": "Background 3 (Our Features)",
          "slug": "background-3"
        },
        {
          "color": "#F1F9F6",
          "name": "Background 4 (Learning Meets)",
          "slug": "background-4"
        },
        {
          "color": "#FFFFFF",
          "name": "Button 1",
          "slug": "button-1"
        }
      ]
    },
    "layout": {
      "contentSize": "960px",
      "wideSize": "1340px"
    },
    "spacing": {
      "defaultSpacingSizes": false,
      "spacingSizes": [
        {
          "name": "Tiny",
          "size": "10px",
          "slug": "20"
        },
        {
          "name": "X-Small",
          "size": "20px",
          "slug": "30"
        },
        {
          "name": "Small",
          "size": "30px",
          "slug": "40"
        },
        {
          "name": "Regular",
          "size": "clamp(30px, 5vw, 50px)",
          "slug": "50"
        },
        {
          "name": "Large",
          "size": "clamp(30px, 7vw, 70px)",
          "slug": "60"
        },
        {
          "name": "X-Large",
          "size": "clamp(50px, 7vw, 90px)",
          "slug": "70"
        },
        {
          "name": "XX-Large",
          "size": "clamp(70px, 10vw, 140px)",
          "slug": "80"
        }
      ],
      "units": ["%", "px", "em", "rem", "vh", "vw"]
    },
    "typography": {
      "writingMode": true,
      "defaultFontSizes": false,
      "fluid": true,
      "fontSizes": [
        {
          "fluid": false,
          "name": "Tiny",
          "size": "clamp(7.350px, calc(0.459rem + ((1vw - 3.2px) * 0.566)), 13.008px)",
          "slug": "tiny"
        },
        {
          "fluid": false,
          "name": "Petite",
          "size": "clamp(8.480px, calc(0.530rem + ((1vw - 3.2px) * 0.653)), 15.008px)",
          "slug": "petite"
        },
        {
          "fluid": false,
          "name": "Small",
          "size": "clamp(9.040px, calc(0.565rem + ((1vw - 3.2px) * 0.696)), 16.000px)",
          "slug": "small"
        },
        {
          "fluid": {
            "max": "19px",
            "min": "16px"
          },
          "name": "Regular",
          "size": "clamp(16px, calc(1rem + ((1vw - 3.2px) * 0.740)), 19px)",
          "slug": "regular"
        },
        {
          "fluid": {
            "max": "19.008px",
            "min": "10.740px"
          },
          "name": "Large",
          "size": "clamp(10.740px, calc(0.671rem + ((1vw - 3.2px) * 0.827)), 19.008px)",
          "slug": "large"
        },
        {
          "fluid": {
            "max": "20px",
            "min": "18px"
          },
          "name": "Extra Large",
          "size": "clamp(18px, calc(1.125rem + ((1vw - 3.2px) * 0.5)), 20px)",
          "slug": "extra-large"
        },
        {
          "fluid": {
            "max": "32.000px",
            "min": "18.080px"
          },
          "name": "Huge",
          "size": "clamp(18.080px, calc(1.130rem + ((1vw - 3.2px) * 1.392)), 32.000px)",
          "slug": "huge"
        },
        {
          "fluid": {
            "max": "42.000px",
            "min": "23.730px"
          },
          "name": "Gigantic",
          "size": "clamp(23.730px, calc(1.483rem + ((1vw - 3.2px) * 1.827)), 42.000px)",
          "slug": "gigantic"
        },
        {
          "fluid": {
            "max": "56.000px",
            "min": "31.640px"
          },
          "name": "Colossus",
          "size": "clamp(31.640px, calc(1.978rem + ((1vw - 3.2px) * 2.436)), 56.000px)",
          "slug": "colossus"
        },
        {
          "fluid": false,
          "name": "Button",
          "size": "clamp(9.610px, calc(0.601rem + ((1vw - 3.2px) * 0.740)), 17.000px)",
          "slug": "button"
        }
      ],
      "fontFamilies": [
        {
          "fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen-Sans, Ubuntu, Cantarell, 'Helvetica Neue', sans-serif",
          "name": "System Font",
          "slug": "system-font"
        },
        {
          "name": "Manrope",
          "slug": "manrope",
          "fontFamily": "Manrope, sans-serif",
          "fontFace": [
            {
              "src": ["file:./assets/fonts/manrope/manrope.ttf"],
              "fontWeight": "200 800",
              "fontStyle": "normal",
              "fontFamily": "Manrope"
            }
          ]
        },
        {
          "name": "Inter",
          "slug": "inter",
          "fontFamily": "Inter, sans-serif",
          "fontFace": [
            {
              "src": ["file:./assets/fonts/inter/inter.ttf"],
              "fontWeight": "200 800",
              "fontStyle": "normal",
              "fontFamily": "Inter"
            }
          ]
        }
      ]
    },
    "custom": {
      "typography": {
        "line-height": {
          "tiny": "1.769",
          "small": "1.933",
          "base": "1.824",
          "large": "1.842",
          "minor": "1.625",
          "standard": "1.6",
          "medium": "1.313",
          "major": "1.238",
          "hero": "1.5",
          "button": "1.4"
        }
      },
      "spacing": {
        "gap": {
          "horizontal": "30px",
          "vertical": "30px"
        }
      }
    },
    "useRootPaddingAwareAlignments": true
  },
  "styles": {
    "color": {
      "background": "var:preset|color|background-1",
      "text": "var:preset|color|accent-3"
    },
    "spacing": {
      "blockGap": "var:preset|spacing|40",
      "padding": {
        "left": "var:preset|spacing|50",
        "right": "var:preset|spacing|50"
      }
    },
    "typography": {
      "fontFamily": "var:preset|font-family|inter",
      "fontSize": "var:preset|font-size|regular",
      "fontWeight": "300",
      "letterSpacing": "-0.1px",
      "lineHeight": "var:custom|typography|line-height|base"
    },
    "blocks": {
      "core/avatar": {
        "border": {
          "radius": "100px"
        }
      },
      "core/button": {
        "color": {
          "background": "var:preset|color|primary",
          "text": "var:preset|color|button-1"
        },
        "typography": {
          "fontFamily": "var:preset|font-family|manrope",
          "fontSize": "var:preset|font-size|button",
          "fontWeight": "600",
          "lineHeight": "var:custom|typography|line-height|button",
          "textTransform": "capitalize"
        },
        "spacing": {
          "padding": {
            "top": "16px",
            "bottom": "16px",
            "left": "36px",
            "right": "36px"
          }
        },
        "border": {
          "radius": "50px"
        },
        ":hover": {
          "color": {
            "background": "color-mix(in srgb, var(--wp--preset--color--primary) 85%, transparent)",
            "text": "var:preset|color|background-1"
          }
        },
        ":focus": {
          "outline": {
            "color": "var:preset|color|paragraph",
            "offset": "2px"
          }
        },
        "variations": {
          "outline": {
            "border": {
              "color": "currentColor",
              "width": "1px"
            },
            "css": ".wp-block-button__link:not(.has-background):hover {background-color:color-mix(in srgb, var(--wp--preset--color--primary) 5%, transparent);}",
            "spacing": {
              "padding": {
                "bottom": "calc(16px - 1px)",
                "left": "calc(36px - 1px)",
                "right": "calc(36px - 1px)",
                "top": "calc(16px - 1px)"
              }
            }
          }
        },
        "css": "text-wrap: pretty;"
      },
      "core/buttons": {
        "spacing": {
          "blockGap": "16px"
        }
      },
      "core/columns": {
        "spacing": {
          "blockGap": "var:preset|spacing|50"
        }
      },
      "core/code": {
        "typography": {
          "fontFamily": "var:preset|font-family|inter",
          "fontSize": "var:preset|font-size|regular",
          "fontWeight": "300"
        },
        "color": {
          "background": "var:preset|color|background-3",
          "text": "var:preset|color|heading"
        },
        "spacing": {
          "padding": {
            "right": "var:preset|spacing|40",
            "bottom": "var:preset|spacing|40",
            "left": "var:preset|spacing|40",
            "top": "var:preset|spacing|40"
          }
        }
      },
      "core/comment-author-name": {
        "color": {
          "text": "var:preset|color|paragraph"
        },
        "elements": {
          "link": {
            "color": {
              "text": "var:preset|color|paragraph"
            },
            "typography": {
              "textDecoration": "none"
            },
            ":hover": {
              "typography": {
                "textDecoration": "underline"
              }
            }
          }
        },
        "typography": {
          "fontSize": "var:preset|font-size|small"
        },
        "spacing": {
          "margin": {
            "top": "5px",
            "bottom": "0px"
          }
        }
      },
      "core/comment-content": {
        "typography": {
          "fontSize": "var:preset|font-size|regular"
        },
        "spacing": {
          "margin": {
            "top": "var:preset|spacing|30",
            "bottom": "var:preset|spacing|30"
          }
        }
      },
      "core/comment-date": {
        "typography": {
          "fontSize": "var:preset|font-size|small"
        },
        "color": {
          "text": "var:preset|color|heading"
        },
        "elements": {
          "link": {
            "color": {
              "text": "var:preset|color|heading"
            }
          }
        }
      },
      "core/comment-edit-link": {
        "elements": {
          "link": {
            "color": {
              "text": "var:preset|color|heading"
            }
          }
        },
        "typography": {
          "fontSize": "var:preset|font-size|small"
        }
      },
      "core/comment-reply-link": {
        "elements": {
          "link": {
            "color": {
              "text": "var:preset|color|heading"
            }
          }
        },
        "typography": {
          "fontSize": "var:preset|font-size|small"
        }
      },
      "core/post-comments-form": {
        "css": "& textarea, input:not([type=submit]){border-radius:.25rem; border-color: var(--wp--preset--color--accent-6) !important;} & input[type=checkbox]{margin:0 .2rem 0 0 !important;} & label {font-size: var(--wp--preset--font-size--small); }",
        "typography": {
          "fontSize": "var:preset|font-size|regular"
        },
        "spacing": {
          "padding": {
            "top": "var:preset|spacing|40",
            "bottom": "var:preset|spacing|40"
          }
        }
      },
      "core/comments-pagination": {
        "typography": {
          "fontSize": "var:preset|font-size|regular"
        },
        "spacing": {
          "margin": {
            "top": "var:preset|spacing|40",
            "bottom": "var:preset|spacing|40"
          }
        }
      },
      "core/comments-pagination-next": {
        "typography": {
          "fontSize": "var:preset|font-size|regular"
        }
      },
      "core/comments-pagination-numbers": {
        "typography": {
          "fontSize": "var:preset|font-size|regular"
        }
      },
      "core/comments-pagination-previous": {
        "typography": {
          "fontSize": "var:preset|font-size|regular"
        }
      },
      "core/post-date": {
        "color": {
          "text": "var:preset|color|paragraph"
        },
        "elements": {
          "link": {
            "color": {
              "text": "var:preset|color|paragraph"
            },
            ":hover": {
              "typography": {
                "textDecoration": "underline"
              }
            },
            "typography": {
              "textDecoration": "none"
            }
          }
        },
        "typography": {
          "fontSize": "var:preset|font-size|small"
        }
      },
      "core/post-navigation-link": {
        "typography": {
          "fontSize": "var:preset|font-size|regular"
        }
      },
      "core/post-terms": {
        "css": "& a { white-space: nowrap; }",
        "typography": {
          "fontSize": "var:preset|font-size|small",
          "fontWeight": "600"
        }
      },
      "core/post-title": {
        "elements": {
          "link": {
            ":hover": {
              "typography": {
                "textDecoration": "underline"
              }
            },
            "typography": {
              "textDecoration": "none"
            }
          }
        }
      },
      "core/quote": {
        "border": {
          "style": "solid",
          "width": "0 0 0 2px",
          "color": "currentColor"
        },
        "spacing": {
          "blockGap": "var:preset|spacing|30",
          "margin": {
            "left": "0",
            "right": "0"
          },
          "padding": {
            "top": "var:preset|spacing|30",
            "right": "var:preset|spacing|40",
            "bottom": "var:preset|spacing|30",
            "left": "var:preset|spacing|40"
          }
        },
        "typography": {
          "fontSize": "var:preset|font-size|large",
          "fontWeight": "300"
        },
        "elements": {
          "cite": {
            "typography": {
              "fontSize": "var:preset|font-size|small",
              "fontStyle": "normal",
              "fontWeight": "300"
            },
            "css": "& sub { font-size: 0.65em }"
          }
        },
        "css": "&.has-text-align-right { border-width: 0 2px 0 0; } &.has-text-align-center { border-width: 0;border-inline: 0; padding-inline: 0; }",
        "variations": {
          "plain": {
            "border": {
              "color": "transparent",
              "style": "none",
              "width": "0",
              "radius": "0"
            },
            "spacing": {
              "padding": {
                "top": "0",
                "right": "0",
                "bottom": "0",
                "left": "0"
              }
            }
          }
        }
      },
      "core/pullquote": {
        "typography": {
          "fontSize": "var:preset|font-size|huge",
          "fontWeight": "300",
          "lineHeight": "1.2"
        },
        "elements": {
          "cite": {
            "typography": {
              "fontSize": "var:preset|font-size|small",
              "fontStyle": "normal"
            }
          }
        },
        "spacing": {
          "padding": {
            "bottom": "var:preset|spacing|30",
            "top": "var:preset|spacing|30"
          }
        },
        "css": "& p:last-of-type {margin-bottom: var(--wp--preset--spacing--30);}"
      },
      "core/query-pagination": {
        "typography": {
          "fontSize": "var:preset|font-size|regular",
          "fontWeight": "500"
        }
      },
      "core/search": {
        "css": "& .wp-block-search__input{border-radius:3.125rem;padding-left:1.5625rem;padding-right:1.5625rem;border-color:var(--wp--preset--color--accent-6);}",
        "typography": {
          "fontSize": "var:preset|font-size|regular",
          "lineHeight": "1.6"
        },
        "elements": {
          "button": {
            "border": {
              "radius": "3.125rem"
            },
            "spacing": {
              "margin": {
                "left": "1.125rem"
              }
            },
            ":hover": {
              "border": {
                "color": "transparent"
              }
            }
          }
        }
      },
      "core/separator": {
        "border": {
          "color": "currentColor",
          "style": "solid",
          "width": "0 0 1px 0"
        },
        "color": {
          "text": "var:preset|color|accent-6"
        },
        "spacing": {
          "margin": {
            "top": "var:preset|spacing|50",
            "bottom": "var:preset|spacing|50"
          }
        },
        "variations": {
          "wide": {
            "css": " &:not(.alignfull){max-width: var(--wp--style--global--wide-size) !important;}"
          }
        }
      },
      "core/site-tagline": {
        "typography": {
          "fontSize": "var:preset|font-size|regular"
        }
      },
      "core/site-title": {
        "typography": {
          "fontWeight": "700",
          "letterSpacing": "-.5px"
        },
        "elements": {
          "link": {
            "typography": {
              "textDecoration": "none"
            },
            ":hover": {
              "typography": {
                "textDecoration": "underline"
              }
            }
          }
        }
      },
      "core/term-description": {
        "color": {
          "text": "var:preset|color|background-1"
        },
        "typography": {
          "fontSize": "var:preset|font-size|regular",
          "lineHeight": "var:custom|typography|line-height|base"
        }
      },
      "core/navigation": {
        "typography": {
          "fontSize": "var:preset|font-size|regular"
        },
        "elements": {
          "link": {
            ":hover": {
              "typography": {
                "textDecoration": "underline"
              }
            },
            "typography": {
              "textDecoration": "none"
            }
          }
        }
      },
      "core/list": {
        "css": "& li{margin-top: 0.5rem;}",
        "spacing": {
          "margin": {
            "top": "0",
            "bottom": "var:preset|spacing|40"
          },
          "padding": {
            "left": "var:preset|spacing|40"
          }
        }
      },
      "core/image": {
        "spacing": {
          "margin": {
            "top": "0",
            "bottom": "var:preset|spacing|50"
          }
        }
      },
      "core/paragraph": {
        "color": {
          "text": "var:preset|color|accent-3"
        },
        "typography": {
          "fontSize": "var:preset|font-size|regular",
          "lineHeight": "var:custom|typography|line-height|base",
          "fontWeight": "300",
          "fontFamily": "var:preset|font-family|inter"
        },
        "spacing": {
          "margin": {
            "top": "0",
            "bottom": "var:preset|spacing|40"
          }
        },
        "css": "text-wrap: pretty;"
      },
      "core/group": {
        "spacing": {
          "blockGap": "var:preset|spacing|40"
        }
      },
      "core/post-content": {
        "spacing": {
          "blockGap": "var:preset|spacing|40"
        }
      },
      "core/cover": {
        "elements": {
          "link": {
            "color": {
              "text": "var:preset|color|background-1"
            }
          }
        }
      },
      "core/accordion": {
        "spacing": {
          "blockGap": "20px"
        }
      },
      "core/accordion-item": {
        "color": {
          "background": "var:preset|color|background-3"
        },
        "typography": {
          "fontSize": "var:preset|font-size|extra-large"
        },
        "border": {
          "radius": "12px",
          "color": "var:preset|color|accent-6"
        },
        "spacing": {
          "padding": {
            "top": "0px",
            "right": "0px",
            "bottom": "0px",
            "left": "0px"
          }
        }
      },
      "core/accordion-heading": {
        "color": {
          "background": "var:preset|color|background-3",
          "text": "var:preset|color|heading"
        },
        "typography": {
          "fontFamily": "var:preset|font-family|manrope",
          "fontSize": "var:preset|font-size|extra-large",
          "fontWeight": "700",
          "lineHeight": "1.6"
        },
        "spacing": {
          "padding": {
            "top": "24px",
            "right": "35px",
            "bottom": "24px",
            "left": "35px"
          }
        },
        "border": {
          "radius": {
            "topLeft": "12px",
            "topRight": "12px",
            "bottomLeft": "0px",
            "bottomRight": "0px"
          }
        }
      },
      "core/accordion-panel": {
        "color": {
          "background": "var:preset|color|background-3",
          "text": "var:preset|color|accent-3"
        },
        "typography": {
          "fontSize": "var:preset|font-size|regular",
          "lineHeight": "var:custom|typography|line-height|base"
        },
        "spacing": {
          "padding": {
            "top": "24px",
            "right": "35px",
            "bottom": "24px",
            "left": "35px"
          },
          "margin": {
            "top": "0px",
            "right": "0px",
            "bottom": "0px",
            "left": "0px"
          }
        },
        "border": {
          "radius": {
            "topLeft": "0px",
            "topRight": "0px",
            "bottomLeft": "12px",
            "bottomRight": "12px"
          }
        }
      }
    },
    "elements": {
      "button": {
        "color": {
          "background": "var:preset|color|primary",
          "text": "var:preset|color|background-1"
        },
        ":focus": {
          "outline": {
            "color": "var:preset|color|paragraph",
            "offset": "2px"
          }
        },
        ":hover": {
          "color": {
            "background": "color-mix(in srgb, var(--wp--preset--color--primary) 85%, transparent)",
            "text": "var:preset|color|background-1"
          },
          "border": {
            "color": "transparent"
          }
        },
        "spacing": {
          "padding": {
            "bottom": "16px",
            "left": "36px",
            "right": "36px",
            "top": "16px"
          }
        },
        "typography": {
          "fontSize": "var:preset|font-size|button"
        }
      },
      "caption": {
        "typography": {
          "fontSize": "var:preset|font-size|small",
